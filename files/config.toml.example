# ExpressVPN Control Server Authentication Configuration
# Copy this file to config.toml and customize the credentials.
# Multiple roles are supported; each role can protect a subset of routes.

# -----------------------------------------------------------------------------
# BASIC AUTH ROLE (username/password)
# -----------------------------------------------------------------------------
[[roles]]
name = "admin"
auth = "basic"
username = "admin"
password = "changeme"
routes = [
  "GET /v1/status",
  "GET /v1/servers",
  "GET /v1/dns",
  "GET /v1/ip",
  "GET /v1/dnsleak",
  "GET /v1/health",
  "POST /v1/connect",
  "POST /v1/disconnect"
]

# -----------------------------------------------------------------------------
# API KEY ROLE (Bearer token header)
# -----------------------------------------------------------------------------
# [[roles]]
# name = "automation"
# auth = "api_key"
# api_key = "sk-1234567890abcdef"
# routes = [
#   "GET /v1/status",
#   "GET /v1/ip",
#   "GET /v1/health"
# ]

# -----------------------------------------------------------------------------
# OPEN ROLE (no authentication) - USE FOR TESTING ONLY
# -----------------------------------------------------------------------------
# [[roles]]
# name = "internal-monitoring"
# auth = "none"
# routes = [
#   "GET /v1/health"
# ]

# Notes:
# - Omit the routes list or use "*" to allow all endpoints for a role.
# - The first matching role with valid credentials wins.
# - Requests to routes not listed in any role return HTTP 403.
